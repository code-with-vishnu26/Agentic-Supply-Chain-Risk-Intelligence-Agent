# Supply Chain Risk Intelligence Agent — Environment Variables

# Project
PROJECT_NAME=Supply Chain Risk Intelligence Agent
API_V1_STR=/api/v1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database — PostgreSQL (production with Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chain_guard_ai

# Standalone mode — set USE_SQLITE=True to run without Docker/PostgreSQL
USE_SQLITE=True
SQLITE_URL=sqlite+aiosqlite:///./supply_chain.db

# Redis (for Celery — optional in standalone mode)
REDIS_URL=redis://localhost:6379/0

# Simulation Mode — set True to use simulated data instead of real APIs
SIMULATION_MODE=True

# External APIs (only needed when SIMULATION_MODE=False)
OPENAI_API_KEY=
NEWS_API_KEY=
WEATHER_API_KEY=

# Security
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
